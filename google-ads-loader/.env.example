# Google Ads API credentials
# Obtain from Google Cloud Console + Google Ads API Center
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_oauth2_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_oauth2_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_oauth2_refresh_token
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890   # MCC account ID (digits only, no dashes)

# Anthropic API (used for daily analysis summaries)
ANTHROPIC_API_KEY=sk-ant-...

# ClickUp API
# API token: ClickUp → Settings → Apps → API Token
# List ID: open a ClickUp list, copy the numeric ID from the URL
# Assignee ID: ClickUp user ID (numeric) — get via GET /api/v2/team
CLICKUP_API_TOKEN=pk_...
CLICKUP_LIST_ID=000000000
CLICKUP_ASSIGNEE_ID=00000000

# Discord webhook for notifications
# Discord Server → Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL = ""

# CTM (Call Tracking Metrics) — optional, leave blank to skip
# Obtain from CTM → Settings → API
CTM_API_KEY=your_ctm_api_key
CTM_API_SECRET=your_ctm_api_secret
CTM_ACCOUNT_ID=your_ctm_account_id
