# Launchpad Labs — participant env file
# Copy this to .env and fill in the values Thanh gives you.
# DO NOT commit .env — it's git-ignored.

# ── LaunchFlow work tracker ─────────────────────────────────────────────────
# Your name as shown on the Live Work tab (Discord handle or first name).
LAUNCHFLOW_MEMBER_NAME=

# Team Ops Supabase — Thanh provides these for the event.
LAUNCHFLOW_SUPABASE_URL=
LAUNCHFLOW_SUPABASE_SERVICE_KEY=

# ── Launchpad Labs Sandbox Supabase (your playground) ───────────────────────
# Separate project from Executive Vault / Team Ops. Safe to experiment.
SUPABASE_SANDBOX_URL=https://dtfljepvwblmgfcjvkkz.supabase.co
SUPABASE_SANDBOX_ANON_KEY=
SUPABASE_SANDBOX_SERVICE_KEY=

# ── Anthropic / Claude ──────────────────────────────────────────────────────
# For the event, everyone has a Claude Pro subscription — no API key needed
# unless your bounty requires programmatic Claude calls (n8n, batch skills, etc.)
# ANTHROPIC_API_KEY=

# ── Bounty-specific APIs ────────────────────────────────────────────────────
# Thanh adds these per bounty. Don't share across participants.
# WEBFLOW_API_TOKEN=
# SEMRUSH_API_KEY=
# GOOGLE_SEARCH_CONSOLE_SERVICE_ACCOUNT=
# DISCORD_WEBHOOK_URL=

# ── Observability (optional) ────────────────────────────────────────────────
# LAUNCHFLOW_SESSION_ID is normally auto-detected — only override if debugging.
# LAUNCHFLOW_SESSION_ID=
